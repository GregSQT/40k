      "Bash(pytest tests/*)",
      "Bash(python3 -m pytest tests/*)",
      "Bash(python -m pytest tests/*)",
      "Bash(python -m pytest *)",
      "Bash(source .venv/bin/activate && python -m pytest *)",
      "Bash(npx biome lint . *)",
