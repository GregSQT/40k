{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=$(jq -r '.tool_input.file_path // empty' 2>/dev/null); if echo \"$FILE\" | grep -qE '\\.py$'; then cd /home/greg/40k && .venv/bin/python3 -m pytest tests/ -x -q 2>&1 | tail -30; R=${PIPESTATUS[0]}; [ $R -ne 0 ] && exit 2; elif echo \"$FILE\" | grep -qE '\\.(ts|tsx)$'; then cd /home/greg/40k/frontend && npx vitest run 2>&1 | tail -30; R=${PIPESTATUS[0]}; [ $R -ne 0 ] && exit 2; fi",
            "asyncRewake": true,
            "timeout": 120,
            "statusMessage": "Tests de non-régression...",
            "rewakeMessage": "Tests échoués après modification :"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(find * -name *)",
      "Bash(find * -type *)",
      "Bash(wc *)",
      "Bash(stat *)",
      "Bash(ls *)",
      "Bash(source .venv/bin/activate*)",
      "Bash(source /home/greg/40k/.venv/bin/activate)",
      "Bash(.venv/bin/python3 scripts/*)",
      "Bash(.venv/bin/python3 ai/*)",
      "Bash(.venv/bin/python3 engine/*)",
      "Bash(.venv/bin/python3 services/*)",
      "Bash(python3 scripts/*)",
      "Bash(python3 -c *)",
      "Bash(python3 ai/*)",
      "Bash(python3 engine/*)",
      "Bash(python3 services/*)",
      "Bash(echo \"PID profiler: $!\")",
      "Bash(echo \"Exit: $?\")",
      "Skill(update-config)",
      "Skill(update-config:*)",
      "Bash(sed -n '830,860p' /home/greg/40k/frontend/src/components/UnitStatusTable.tsx)",
      "Bash(sed -n '1074,1104p' /home/greg/40k/frontend/src/components/UnitStatusTable.tsx)",
      "Bash(npx vitest *)",
      "Bash(source .venv/bin/activate && pytest tests/unit/*)",
      "Bash(cd /home/greg/40k && source .venv/bin/activate && pytest tests/unit/*)",
      "Bash(source .venv/bin/activate && pytest tests/unit/engine/test_move_eligibility.py*)",
      "Bash(source .venv/bin/activate && pytest tests/unit/engine/test_shooting_activation_pool.py*)",
      "Bash(source .venv/bin/activate && pytest tests/unit/engine/test_charge_eligibility.py*)",
      "Bash(source .venv/bin/activate && pytest tests/unit/engine/test_fight_activation_pools.py*)",
      "Bash(source .venv/bin/activate && pytest tests/unit/engine/test_los_cache_invalidation.py*)",
      "Bash(source .venv/bin/activate && pytest tests/unit/engine/ -q*)",
      "Bash(cd /home/greg/40k/frontend && npx vitest run *)"
    ]
  }
}
