    "bot_training": {
      "ratios": {
        "random": 0.1,
        "greedy": 0.2,
        "defensive": 0.2,
        "control": 0.2,
        "aggressive_smart": 0.15,
        "adaptive": 0.15
      },
      "randomness": {
        "greedy": 0.05,
        "defensive": 0.05,
        "control": 0.05,
        "aggressive_smart": 0.05,
        "adaptive": 0.05
      }
    },
    "scenario_sampling": {
      "eval_ref_strict": true,
      "train_objective_count_weights": {
        "1": 0.025,
        "2": 0.025,
        "3": 0.025,
