      "force_random_ratio_end": 0.2,
      "schedule": "linear",
      "freeze_after_progress": 0.8,
      "apply_to": "agent_only"
    },
    "observation_params": {
      "obs_size": 108,
      "perception_radius": 25,
      "max_nearby_units": 12,
      "max_valid_targets": 5,
      "justification": "Refonte spatiale du move (move_action_space_spatial_rework.md). obs_size=108 = vecteur (16 global + 5 squad agg + 7x6 top-k figs + 9x5 enemy slots) ; la grille 32x32x6 (murs/allies/ennemis/EZ/objectifs/niveau) est fournie a part. action_space_size N'EST PLUS configure : la taille de l'action space est DERIVEE du moteur (macro_intents.TOTAL_ACTION_SIZE = 1047 = 1032 micro [1024 cellules de la grille egocentrique + wait + 5 shoot + charge + fight] + 15 macro [5 objectifs x 3 intents]). La recopier ici creait une 2e source de verite qui ne pouvait qu'avoir tort."
    },
    "step_log_buffer_size": 200,
    "vec_normalize": {
      "enabled": true,
      "norm_obs": true,
      "norm_reward": true,
      "clip_obs": 10.0,
      "clip_reward": 10.0,
      "gamma": 0.99
