        "holdout_hard_bot-05"
      ],
      "holdout_hard_opponent_budget_modifier": 1.1,
      "bot_eval_weights": {
        "greedy": 0.23,
        "defensive": 0.23,
        "control": 0.23,
        "aggressive_smart": 0.15,
        "adaptive": 0.16
      },
      "bot_eval_randomness": {
        "greedy": 0.05,
        "defensive": 0.05,
        "control": 0.05,
        "aggressive_smart": 0.05,
        "adaptive": 0.05
