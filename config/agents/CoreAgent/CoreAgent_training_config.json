        "default": 1.0
      },
      "eval_wall_refs": [
        "walls-33.json",
        "walls-mc1.json"
      ],
      "train_selection_mode": "uniform_within_count",
      "eval_selection_mode": "uniform_within_count"
    },
    "training_hard": {
      "enabled": false,
      "target_episode_ratio": 0.3,
      "max_scenario_weight": 4,
      "scenario_names": []
    },
    "unit_rule_forcing": {
