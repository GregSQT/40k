    },
    "roster_pool_schedule": {
      "enabled": true,
      "training": {
        "start_counts": {
          "swarm": 16,
          "troop": 10,
          "elite": 6
        },
        "end_counts": {
          "swarm": 16,
          "troop": 10,
          "elite": 6
        }
      }
    },
    "deployment_random_mix": {
      "enabled": false,
      "training_only": true,
