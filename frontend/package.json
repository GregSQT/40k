{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node ../scripts/copy-configs.js && vite",
    "copy-configs": "node ../scripts/copy-configs.js",
    "tutorial:check-sync": "node scripts/check_tutorial_md_yaml_sync.mjs",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "pretest:frontend": "npm run type-check && npm run lint",
    "check": "npm run typecheck && npm run lint",
    "check:biome": "biome check ..",
    "format:biome": "biome check .. --write",
    "preview": "vite preview",
    "test": "vitest",
    "test:critical": "vitest run --coverage --config vitest.critical.config.ts",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:coverage:global": "vitest run --coverage"
  },
  "dependencies": {
    "js-yaml": "^4.1.0",
    "pixi.js-legacy": "^7.4.3",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^7.8.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.8",
    "@eslint/js": "^9.33.0",
    "@tailwindcss/postcss": "^4.1.13",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/js-yaml": "^4.0.9",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.33.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "jsdom": "^27.0.0",
    "msw": "^2.11.6",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.13",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.39.1",
    "vite": "^7.1.2",
    "vitest": "^3.2.4"
  }
}
